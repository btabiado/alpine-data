# Python
.venv/
.venv-city/
venv/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Generated dashboard output
dashboard.html
# Local convenience copy of the built dashboard. Some setups copy/symlink
# dashboard.html -> index.html to preview at file://.../index.html. The
# PUBLIC site never uses a tracked root index.html: pages.yml regenerates
# from app.py and writes _site/index.html from dashboard.html, and server.py
# serves "/" by live-rendering via dash.render_html(). Ignore so a local
# copy is never recommitted.
index.html
# Lazy-loaded sidecar payloads (whale, etc.) — written by app.py next to
# dashboard.html on every build. Same lifecycle as the HTML itself.
data-*.json
# Carve-out: data-travel.json IS committed as a baseline. The State Dept
# HTML parser in fetch_advisories.py is currently broken (returns 0
# advisories on May 28+), so CI's fetch always falls back to "scrape
# failed; preserving prior data-travel.json (no overwrite)" — which
# requires the file to actually be on disk at checkout time. Once the
# parser is repaired, every CI run will refresh this file in-place; the
# committed copy is just the floor.
!data-travel.json
# Carve-out: data-us_states.json is committed STATIC geometry — 50 states + DC
# SVG paths (pre-projected Albers USA) built once by
# scripts/build_us_state_paths.py from us-atlas. Consumed by the V1 Real Estate
# tab's geographic heat map. Refreshed essentially never (boundaries don't move).
!data-us_states.json
# Carve-out: data-city.json IS committed — the City tab's sidecar, refreshed
# daily by city-daily.yml (mirrors data/real_estate.json's committed-data model)
# so the V1 build always has city data even on a cold CI checkout.
!data-city.json
# Carve-out: data-aviation.json IS committed — the Aviation tab's static sidecar
# (FAA airman/registry data, used-market snapshot, live seed). Refreshed by hand.
!data-aviation.json
# Carve-out: data-opensky.json IS committed — the Aviation tab's live OpenSky
# "airborne now" snapshot, refreshed hourly by aviation-opensky.yml.
!data-opensky.json
# Carve-out: data-opensky-positions.json — trimmed live positions for the Flight Map (hourly cron)
!data-opensky-positions.json
# Carve-out: data-city.schema.json is a hand-authored CONTRACT (not a generated
# sidecar), loaded by the City Pulse conformance tests (tests/test_city_pulse.py).
# The data-*.json rule above matches it by name and was silently keeping it out of
# git — which is why those tests FileNotFound in CI. Un-ignore so it ships.
!docs/city/data-city.schema.json
# V2 builder output mirrors the production layout one level down.
v2/dashboard.html
v2/data-*.json
# Same carve-out for V2's sidecar — see comment above data-travel.json.
!v2/data-travel.json

# Local cached fetches stay on your machine (regenerated every run)
data/*.json
data/*.bak
data/*.farside-vertical.bak
# Stale-fallback cache for flaky third-party APIs (FRED/Glassnode/mempool/Etherscan)
data/.stale/
# Central monitoring snapshot — regenerated by scripts/build_health_status.py
# each CI run before staging. Local copies are throwaway.
data/health/
# NOTE: data/*.csv (ETF flow history) is intentionally NOT ignored — those
# files are tracked so the public dashboard can ship real flow data.
# Update them locally via the dashboard's "Paste CSV…" workflow, then commit.

# Keep schema templates if you want to re-add them later (manually)
!data/.gitkeep
# US real-estate snapshot — committed back by real-estate-daily.yml and read
# by the /real-estate/ page. Updates daily; tracked so the public page works.
!data/real_estate.json
# Metro centroid coords from Census CBSA gazetteer — built by
# scripts/fetch_metro_coords.py, read by the /real-estate/ heat map.
# Rarely changes (annual Census release); tracked so the page works.
!data/metro_coords.json

# LTHCS — local API response cache (raw vendor data, may have redistribution terms)
.cache/

# LTHCS — test pollution: unittest.mock occasionally writes a literal
# `MagicMock/` directory when a patched filesystem call escapes its
# context. Always safe to delete; recurring across the source-module
# test suites.
MagicMock/

# Local env / secrets
.env
.env.local
*.local

# Claude Code worktrees — transient parallel-agent scratch space, never
# committed (the agent's branch is the deliverable, not the worktree dir).
.claude/worktrees/
