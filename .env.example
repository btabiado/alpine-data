# LTHCS Phase 1 — environment variables
# Copy this file to `.env` and fill in your keys.
# NEVER commit `.env` itself.

# Alpha Vantage — https://www.alphavantage.co/support/#api-key
# Free tier: 25 requests/day, used for news sentiment
ALPHA_VANTAGE_API_KEY=

# Finnhub — https://finnhub.io/register
# Free tier: 60 req/min (effectively unlimited for 168 tickers).
# Provides per-ticker news + bullish/bearish sentiment % + analyst
# recommendation trends. Replaces AV as primary news source when set.
FINNHUB_API_KEY=

# FRED — https://fred.stlouisfed.org/docs/api/api_key.html
# Free, used for CPI / Fed Funds / 10Y / unemployment / retail sales
FRED_API_KEY=

# EIA — https://www.eia.gov/opendata/register.php
# Free, used for WTI / Brent / gasoline
EIA_API_KEY=

# SEC EDGAR User-Agent — required by SEC, set to a real email
# Example: "Bryan Tabiadon bryan@example.com"
SEC_USER_AGENT=

# Anthropic — https://console.anthropic.com/
# Used by lthcs/narratives_llm.py to generate LLM-backed narratives with
# prompt caching. Off by default; opt in by setting LTHCS_NARRATIVES_LLM_ENABLED=1.
# ANTHROPIC_API_KEY=

# Optional — runtime toggles
LTHCS_LOG_LEVEL=INFO
LTHCS_CACHE_DIR=.cache/lthcs
LTHCS_DATA_DIR=data/lthcs

# LLM narrative opt-in. Set to 1 to swap templated narratives for
# Anthropic Claude API calls (requires ANTHROPIC_API_KEY above).
# LTHCS_NARRATIVES_LLM_ENABLED=0
# Optional override of the model id; defaults to claude-sonnet-4-5.
# LTHCS_NARRATIVES_LLM_MODEL=claude-sonnet-4-5

# Optional — enable Claude-derived sentiment in the Thesis cascade.
# When set, replaces the AI-news engagement heuristic (commit 36c48aa)
# with real per-ticker LLM classification. ~$0.30/day for 168 tickers
# with prompt caching. Default off.
# LTHCS_LLM_SENTIMENT_ENABLED=0
# LTHCS_LLM_SENTIMENT_MODEL=claude-sonnet-4-5

# ── City tab (fetch_city.py) ───────────────────────────────────────────────
# Socrata app token — https://data.cityofchicago.org/profile/edit/developer_settings
# One free token works across all 5 city portals (Chicago/NYC/LA/Seattle/SF).
# Without it, large tables throttle (429/timeout); with it, full 6/6 City Pulse.
SOCRATA_APP_TOKEN=

# Census ACS — https://api.census.gov/data/key_signup.html
# Context levels: median income/rent/home value + effective property tax.
CENSUS_API_KEY=

# EPA AirNow — https://docs.airnowapi.org/account/request/  (current AQI per city)
AIRNOW_API_KEY=

# FBI Crime Data Explorer, key via api.data.gov — https://api.data.gov/signup/
# Fills Miami's Public Safety pillar (ORI FL0130000).
FBI_CDE_API_KEY=

# BLS LAUS — https://data.bls.gov/registrationEngine/  (unemployment)
# OPTIONAL: works keyless; a key just raises the daily query limit.
BLS_API_KEY=
