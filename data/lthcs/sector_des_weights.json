  "description": "Sector-specific sensitivities for the Demand Environment Score (DES) pillar. Each tilt is in [-1.0, +1.0]: positive means the sector benefits from higher values of that macro signal; negative means it suffers. The DES formula linearly combines macro_tilt[signal] (normalized from raw input to [-1, +1] via signal-specific bounds) with sector_sensitivity[signal], scales by DES_MAGNITUDE_SCALE (V1: 30 points), and adds to neutral baseline 50.0.",
  "signal_normalization": {
    "_comment": "How each raw macro signal is mapped to a [-1, +1] tilt. 'low' -> -1, 'high' -> +1, linear in between, clipped.",
    "cpi_yoy_pct":         {"low": 0.0,  "high": 6.0,  "neutral": 2.0, "_note": "annual CPI inflation; >2% accelerating tilts positive"},
    "fed_funds_pct":       {"low": 0.0,  "high": 6.0,  "neutral": 2.5, "_note": "Fed Funds rate level"},
    "ten_y_yield_pct":     {"low": 1.0,  "high": 6.0,  "neutral": 3.5, "_note": "10Y Treasury yield"},
    "ten_y_30d_change_bp": {"low": -50,  "high": 50,   "neutral": 0,   "_note": "30-day move in 10Y in basis points"},
    "unemployment_pct":    {"low": 2.5,  "high": 8.0,  "neutral": 4.5, "_note": "U-3 unemployment rate; HIGHER unemployment maps to +1, but most sectors have negative sensitivity to that"},
    "wti_oil_usd":         {"low": 40.0, "high": 130.0,"neutral": 75.0,"_note": "WTI crude spot price USD"},
    "real_10y_yield_pct":  {"low": -1.0, "high": 3.5,  "neutral": 1.5, "_note": "10Y TIPS yield (FRED DFII10) — true real rate; compresses long-duration assets"},
    "vix_index":           {"low": 10.0, "high": 40.0, "neutral": 18.0,"_note": "CBOE VIX (FRED VIXCLS) — vol-regime gate; high VIX => risk-off tilt"},
    "m2_yoy_pct":          {"low": -2.0, "high": 12.0, "neutral": 4.0, "_note": "M2 broad money YoY (FRED M2SL) — liquidity, supportive of risk assets when expanding"}
  },
